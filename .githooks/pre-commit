#!/usr/bin/env bash
set -euo pipefail

node scripts/sync-site.mjs

# Stage tracked data outputs, including deletions for removed generated files.
git add -A -- data

# Stage tracked HTML updates and deletions, then add any newly generated HTML files.
git ls-files -z -- '*.html' | xargs -0 git add -u --
find . -type f -name '*.html' -not -path './.git/*' -print0 | xargs -0 git add --
