rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          "prasann.work@gmail.com"
        ];
    }

    function isShortString(value, maxLength) {
      return value is string && value.size() <= maxLength;
    }

    function isOptionalShortString(data, key, maxLength) {
      return !(key in data) || isShortString(data[key], maxLength);
    }

    function isOptionalTimestamp(data, key) {
      return !(key in data) || data[key] is timestamp;
    }

    function isCounter(value) {
      return value is int && value >= 0;
    }

    function isOptionalCounter(data, key) {
      return !(key in data) || isCounter(data[key]);
    }

    function isPuzzleLevel(value) {
      return value is int && value >= 0 && value <= 11;
    }

    function isValidVisitor(data, visitorId) {
      return data.keys().hasOnly([
          "visitorId",
          "createdAt",
          "updatedAt",
          "visitCount",
          "firstPath",
          "lastPath",
          "lastReferrerHost"
        ])
        && data.visitorId == visitorId
        && isCounter(data.visitCount)
        && data.updatedAt == request.time
        && isOptionalTimestamp(data, "createdAt")
        && isOptionalShortString(data, "firstPath", 240)
        && isShortString(data.lastPath, 240)
        && isOptionalShortString(data, "lastReferrerHost", 120);
    }

    function isNewVisitor(data, visitorId) {
      return isValidVisitor(data, visitorId)
        && data.visitCount == 1
        && data.createdAt == request.time
        && isShortString(data.firstPath, 240);
    }

    function isReturningVisitor(data, visitorId) {
      return isValidVisitor(data, visitorId)
        && data.visitorId == resource.data.visitorId
        && data.createdAt == resource.data.createdAt
        && data.firstPath == resource.data.firstPath
        && data.visitCount == resource.data.visitCount + 1;
    }

    function isValidCounters(data) {
      return data.keys().hasOnly([
          "totalVisits",
          "uniqueVisitors",
          "loveLettersUnlocks",
          "updatedAt",
          "lastVisitAt",
          "lastUnlockAt"
        ])
        && isOptionalCounter(data, "totalVisits")
        && isOptionalCounter(data, "uniqueVisitors")
        && isOptionalCounter(data, "loveLettersUnlocks")
        && isOptionalTimestamp(data, "updatedAt")
        && isOptionalTimestamp(data, "lastVisitAt")
        && isOptionalTimestamp(data, "lastUnlockAt");
    }

    function smallInitialCounter(data, key) {
      return !(key in data) || (data[key] is int && data[key] >= 0 && data[key] <= 1);
    }

    function isValidCounterCreate(data) {
      return isValidCounters(data)
        && smallInitialCounter(data, "totalVisits")
        && smallInitialCounter(data, "uniqueVisitors")
        && smallInitialCounter(data, "loveLettersUnlocks");
    }

    function counterDoesNotJump(data, key) {
      return !(key in data)
        || (!(key in resource.data) && data[key] <= 1)
        || (
          key in resource.data
          && data[key] >= resource.data[key]
          && data[key] <= resource.data[key] + 1
        );
    }

    function isValidCounterUpdate(data) {
      return isValidCounters(data)
        && counterDoesNotJump(data, "totalVisits")
        && counterDoesNotJump(data, "uniqueVisitors")
        && counterDoesNotJump(data, "loveLettersUnlocks");
    }

    function isValidPuzzleProgress(data, visitorId) {
      return data.keys().hasOnly([
          "visitorId",
          "createdAt",
          "updatedAt",
          "highestLevel",
          "lastLevel",
          "lastPath",
          "hasWon",
          "wonAt",
          "lastWinPath",
          "countedAsSolver",
          "solverCountedAt"
        ])
        && data.visitorId == visitorId
        && isPuzzleLevel(data.highestLevel)
        && isPuzzleLevel(data.lastLevel)
        && data.lastLevel <= data.highestLevel
        && data.hasWon is bool
        && data.updatedAt == request.time
        && isOptionalTimestamp(data, "createdAt")
        && isShortString(data.lastPath, 240)
        && (
          !("countedAsSolver" in data)
          || (
            data.countedAsSolver == true
            && data.solverCountedAt is timestamp
          )
        )
        && (
          data.hasWon == false
          || (
            data.hasWon == true
            && data.wonAt is timestamp
            && isOptionalShortString(data, "lastWinPath", 240)
          )
        )
        && (
          data.hasWon == true
          || (
            !("wonAt" in data)
            && !("lastWinPath" in data)
            && !("countedAsSolver" in data)
            && !("solverCountedAt" in data)
          )
        );
    }

    function isNewPuzzleProgress(data, visitorId) {
      return isValidPuzzleProgress(data, visitorId)
        && data.createdAt == request.time
        && (
          data.hasWon == false
          || data.wonAt == request.time
        );
    }

    function puzzleCreatedAtDidNotChange(data) {
      return data.createdAt == resource.data.createdAt;
    }

    function puzzleHighestLevelDoesNotGoBack(data) {
      return data.highestLevel >= resource.data.highestLevel;
    }

    function puzzleWinStateDoesNotGoBack(data) {
      return (
          resource.data.hasWon == false
          && (
            data.hasWon == false
            || (
              data.hasWon == true
              && data.wonAt == request.time
            )
          )
        )
        || (
          resource.data.hasWon == true
          && data.hasWon == true
          && data.wonAt == resource.data.wonAt
        );
    }

    function puzzleSolverCountStateIsValid(data) {
      return (
          !("countedAsSolver" in data)
          && !("countedAsSolver" in resource.data)
        )
        || (
          !("countedAsSolver" in resource.data)
          && data.countedAsSolver == true
          && data.solverCountedAt == request.time
        )
        || (
          "countedAsSolver" in resource.data
          && data.countedAsSolver == resource.data.countedAsSolver
          && (
            !("solverCountedAt" in resource.data)
            || data.solverCountedAt == resource.data.solverCountedAt
          )
        );
    }

    function isPuzzleProgressUpdate(data, visitorId) {
      return isValidPuzzleProgress(data, visitorId)
        && data.visitorId == resource.data.visitorId
        && puzzleCreatedAtDidNotChange(data)
        && puzzleHighestLevelDoesNotGoBack(data)
        && puzzleWinStateDoesNotGoBack(data)
        && puzzleSolverCountStateIsValid(data);
    }

    function isValidPublicSecretPuzzleStats(data) {
      return data.keys().hasOnly([
          "solverCount",
          "updatedAt",
          "lastSolvedAt"
        ])
        && isCounter(data.solverCount)
        && data.updatedAt == request.time
        && data.lastSolvedAt == request.time;
    }

    function isValidPublicSecretPuzzleStatsCreate(data) {
      return isValidPublicSecretPuzzleStats(data)
        && data.solverCount == 1;
    }

    function isValidPublicSecretPuzzleStatsUpdate(data) {
      return isValidPublicSecretPuzzleStats(data)
        && data.solverCount == resource.data.solverCount + 1;
    }

    match /visitors/{visitorId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn()
        && visitorId == request.auth.uid
        && isNewVisitor(request.resource.data, visitorId);
      allow update: if isSignedIn()
        && visitorId == request.auth.uid
        && isReturningVisitor(request.resource.data, visitorId);
      allow delete: if false;
    }

    match /analytics/site {
      allow get: if isAdmin();
      allow list: if false;
      allow create: if isSignedIn() && isValidCounterCreate(request.resource.data);
      allow update: if isSignedIn() && isValidCounterUpdate(request.resource.data);
      allow delete: if false;
    }

    match /puzzleProgress/{visitorId} {
      allow get: if isAdmin() || (isSignedIn() && visitorId == request.auth.uid);
      allow list: if isAdmin();
      allow create: if isSignedIn()
        && visitorId == request.auth.uid
        && isNewPuzzleProgress(request.resource.data, visitorId);
      allow update: if isSignedIn()
        && visitorId == request.auth.uid
        && isPuzzleProgressUpdate(request.resource.data, visitorId);
      allow delete: if false;
    }

    match /publicStats/secretPuzzle {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn()
        && isValidPublicSecretPuzzleStatsCreate(request.resource.data);
      allow update: if isSignedIn()
        && isValidPublicSecretPuzzleStatsUpdate(request.resource.data);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
